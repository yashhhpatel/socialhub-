# Copy to .env and fill in real values for local development.
# Every variable here is validated at boot by src/config — the app refuses
# to start if a required one is missing or malformed (see env.validation.ts).

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database ---
DATABASE_URL=postgresql://socialhub:socialhub@localhost:5432/socialhub

# --- Auth (JWT) ---
# Generate a real secret locally, never reuse this placeholder:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_generated_64_char_hex_secret_before_running
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30

# --- Token encryption (Milestone 2.1) ---
# MUST be exactly 32 bytes hex-encoded (64 hex chars) — TokenEncryptionService
# validates this exact length at boot. Generate a real one locally:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=replace_with_a_generated_64_char_hex_key_before_running

# --- Instagram OAuth (Milestone 2.2) ---
# From your Meta Developer App dashboard (developers.facebook.com) —
# "Business Login for Instagram" product, NOT the deprecated Basic
# Display API. See src/social-accounts/adapters/instagram.adapter.ts.
#
# UNLIKE every variable above, these are deliberately NOT added to
# env.validation.ts's required schema — connecting Instagram is an
# optional feature a dev may not have Meta credentials for yet, and the
# rest of the app (auth, health, etc.) has no reason to refuse to boot
# over it. Missing/invalid values here fail loudly but lazily, only when
# someone actually attempts POST /social-accounts/instagram/connect —
# see InstagramAdapter's use of configService.getOrThrow() inside its
# methods, not its constructor.
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/social-accounts/instagram/callback

# --- X (Twitter) OAuth (Milestone 2.3) ---
# From your X Developer Portal app (developer.x.com) — OAuth 2.0 with
# PKCE. See src/social-accounts/adapters/x.adapter.ts. Same reasoning as
# the Instagram vars above: deliberately NOT boot-required.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/social-accounts/x/callback

# --- Frontend URL (Milestone 2.4) ---
# Used only to redirect the browser back to the app after an OAuth
# callback completes (see social-accounts.controller.ts). Optional — if
# unset, the callback returns plain JSON instead of redirecting, which
# still works fine for testing the API directly via curl/Postman.
#
# Flutter Web's local dev server picks a RANDOM port by default
# (`flutter run -d chrome`), so there's no universal correct value here.
# Run with a fixed port to make this useful locally:
#   flutter run -d chrome --web-port=5000
# then:
# FRONTEND_URL=http://localhost:5000
FRONTEND_URL=

# --- Cloudinary (Milestone 3.2) ---
# From your Cloudinary dashboard (cloudinary.com/console). Same reasoning
# as the OAuth vars above: deliberately NOT boot-required — media upload
# is an optional feature a dev may not have Cloudinary credentials for
# yet. An upload attempt without these configured fails with a clear
# Cloudinary API error at call time, not a cryptic one.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
