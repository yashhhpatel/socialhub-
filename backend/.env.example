# Copy to .env and fill in real values for local development.
# Every variable here is validated at boot by src/config — the app refuses
# to start if a required one is missing or malformed (see env.validation.ts).

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (added in Milestone 0.4; present here as a placeholder so
#     .env.example already documents the full Phase-0 surface) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/socialhub
