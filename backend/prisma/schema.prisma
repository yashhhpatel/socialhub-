// SocialHub — Prisma schema
//
// Models are introduced incrementally, milestone by milestone, rather than
// all at once — see docs/database/SocialHub_Database_Design.md for the
// full target schema this grows into.
//
// Milestone 1.2 adds Organization, plus orgId/role on User. Organization
// only carries the fields needed so far (name, planTier, requiresApproval)
// — relations to BrandKit/SsoConfig/etc. are added in the milestones that
// introduce those models, not stubbed in now.
//
// Milestone 2.2 adds SocialAccount. Platform enum values match
// PlatformName exactly (see social-accounts/adapters/adapter.interface.ts)
// — that file's comment already flagged this alignment back in 2.1.
//
// Milestone 3.1 adds ContentAsset. Deliberately NOT included yet:
// templateId/brandKitId — those FKs reference Template/BrandKit models
// that don't exist until Phase 9, same reasoning as every other deferred
// FK in this file (User.orgId before Organization existed, etc.).
// approvalStatus IS included now despite approval enforcement itself not
// arriving until Milestone 13.2 — every asset has some approval state
// from creation regardless of whether an org requires approval, so this
// isn't a forward FK dependency the way templateId/brandKitId are.
//
// NOTE (Prisma 7+): the datasource `url` no longer lives here — Prisma 7
// moved connection URLs to prisma.config.ts (see ../prisma.config.ts).
// schema.prisma is now purely structural (models + provider), never
// environment-dependent. See https://pris.ly/d/config-datasource.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanTier {
  free
  starter
  pro
  enterprise
}

enum UserRole {
  owner
  admin
  editor
  viewer
}

enum Platform {
  instagram
  facebook
  threads
  x
  linkedin
}

enum SocialAccountStatus {
  connected
  expired
  revoked
  error
}

enum ContentAssetType {
  image
  video
}

enum ApprovalStatus {
  draft
  pending_approval
  approved
  rejected
}

model Organization {
  id               String          @id @default(uuid())
  name             String
  planTier         PlanTier        @default(free)
  requiresApproval Boolean         @default(false)
  users            User[]
  socialAccounts   SocialAccount[]
  contentAssets    ContentAsset[]
  createdAt        DateTime        @default(now())

  @@map("organization")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(editor)
  orgId         String
  organization  Organization   @relation(fields: [orgId], references: [id])
  refreshTokens RefreshToken[]
  createdAssets ContentAsset[] @relation("CreatedAssets")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([orgId])
  @@map("user")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, revoked])
  @@map("refresh_token")
}

model SocialAccount {
  id                String              @id @default(uuid())
  orgId             String
  organization      Organization        @relation(fields: [orgId], references: [id])
  platform          Platform
  externalAccountId String
  // Encrypted via TokenEncryptionService (Milestone 2.1) before ever
  // touching the database — never stored raw. See social-accounts.service.ts.
  accessTokenEnc    String
  refreshTokenEnc   String?
  expiresAt         DateTime?
  status            SocialAccountStatus @default(connected)
  createdAt         DateTime            @default(now())

  // Prevents the same external Instagram/X/etc. account being connected
  // twice to one org.
  @@unique([orgId, platform, externalAccountId])
  @@index([orgId])
  @@map("social_account")
}

model ContentAsset {
  id             String           @id @default(uuid())
  orgId          String
  organization   Organization     @relation(fields: [orgId], references: [id])
  createdById    String
  createdBy      User             @relation("CreatedAssets", fields: [createdById], references: [id])
  type           ContentAssetType
  // Arbitrary editor canvas state (width/height/layers/etc.) — schema
  // owned by the editor (Milestone 3.3+), not by this model. Validated
  // at the API boundary (see content/dto/canvas-json.dto.ts), not by
  // the database.
  canvasJson     Json
  approvalStatus ApprovalStatus   @default(draft)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([orgId])
  @@index([orgId, approvalStatus])
  @@map("content_asset")
}
